# Spring Boot 로컬 실행용 설정 예시입니다.
# 이 파일을 application-local.yml로 복사한 뒤 사용하세요.
# 실제 DB 접속 정보는 환경변수로 주입합니다.

spring:
  datasource:
    url: ${DB_URL}
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: ${JPA_DDL_AUTO:update}
    open-in-view: false
    properties:
      hibernate:
        format_sql: true

logging:
  level:
    org.hibernate.SQL: debug